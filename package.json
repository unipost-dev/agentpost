{
  "name": "@unipost/agentpost",
  "version": "0.1.0",
  "description": "AI-native CLI for multi-platform social posting. Describe what you shipped, AI posts it everywhere.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agentpost": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build",
    "test": "node --test --experimental-strip-types test/*.test.ts"
  },
  "keywords": [
    "ai",
    "cli",
    "social-media",
    "twitter",
    "linkedin",
    "bluesky",
    "claude",
    "anthropic",
    "unipost",
    "indie-hacker",
    "developer-tools"
  ],
  "license": "MIT",
  "author": "UniPost <hi@unipost.dev>",
  "homepage": "https://github.com/unipost-dev/agentpost",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unipost-dev/agentpost.git"
  },
  "bugs": {
    "url": "https://github.com/unipost-dev/agentpost/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.21.0",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "kleur": "^4.1.5",
    "openai": "^4.71.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
